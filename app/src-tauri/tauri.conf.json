{
  "productName": "GEWIS Remote Desktop",
  "version": "1.2.0",
  "identifier": "nl.gewis.rdp",

  "build": {
    "frontendDist": "../src"
  },

  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },

  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "",
        "width": 320,
        "height": 500,
        "resizable": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
