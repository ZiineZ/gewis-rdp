# ── Rust / Cargo build artefacts ──────────────────────────────────────────────
app/src-tauri/target/
app/src-tauri/Cargo.lock
**/*.rs.bk

# ── Tauri-generated files ─────────────────────────────────────────────────────
app/src-tauri/gen/

# ── Bundled FreeRDP binaries ──────────────────────────────────────────────────
# These are produced by setup.sh + the bundling step. They're large (~5 MB)
# and architecture-specific, so we don't track them in git.
app/resources/
app/src-tauri/resources/

# ── Built FreeRDP from source ─────────────────────────────────────────────────
# setup.sh downloads + builds FreeRDP into these directories.
freerdp-krb5-build/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
# (note: we intentionally don't ignore "Icon?" because it would catch icon.icns)

# Thumbnails / Spotlight / Trashes
.Spotlight-V100
.Trashes
.fseventsd
.DocumentRevisions-V100
.TemporaryItems

# ── Editors / IDEs ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Python (the old prototype launcher.py) ────────────────────────────────────
__pycache__/
*.pyc

# ── Kerberos credential caches (just in case) ─────────────────────────────────
krb5cc_*
*.keytab

# ── Generated icon source ─────────────────────────────────────────────────────
# Generated by build-app.sh from the SVG; sized PNGs/icns are checked in.
app/src-tauri/icons/icon_source.png
